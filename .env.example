# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored; `.env.example` is committed as documentation.

# ----- DB backend selection -----
# 'sqlite'   = local file at config.DB_PATH (offline / dev). DEFAULT.
# 'postgres' = Supabase / any libpq-compatible Postgres
DB_BACKEND=sqlite

# ----- Supabase Postgres connection (only required if DB_BACKEND=postgres) -----
# Find this in Supabase dashboard:
#   Project Settings → Database → Connection string → URI
# IMPORTANT: if your password contains special chars (@, #, /, :, etc.),
# URL-encode them. e.g. '@' → '%40', '#' → '%23'.
SUPABASE_DB_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Optional: project URL for any future Supabase REST/Storage usage.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
