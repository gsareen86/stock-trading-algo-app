# -----------------------------------------------------------------------
# Trading Bot — Environment Variables Template
# Copy this file to .env and fill in your values.
# .env is gitignored and will NEVER be committed to GitHub.
# -----------------------------------------------------------------------

# ---- LLM Provider Selection -------------------------------------------
# Choose which LLM provider to use. Supported values:
#   openrouter  (default) — free models available, no Anthropic account needed
#   anthropic             — Claude models, requires paid Anthropic account
LLM_PROVIDER=openrouter

# ---- OpenRouter (default provider) ------------------------------------
# Get your free API key at https://openrouter.ai/keys
# Free models: visit https://openrouter.ai/models and filter by "Free"
OPENROUTER_API_KEY=sk-or-v1-YOUR_KEY_HERE

# Model to use on OpenRouter. Free options (verify current availability at openrouter.ai/models):
#   google/gemma-3-27b-it:free       — Gemma 3 27B (recommended free model)
#   google/gemma-3-12b-it:free       — Gemma 3 12B (faster, less capable)
#   meta-llama/llama-3.3-70b-instruct:free
#   mistralai/mistral-7b-instruct:free
OPENROUTER_MODEL=google/gemma-3-27b-it:free

# ---- Anthropic (alternative provider) ---------------------------------
# Only needed when LLM_PROVIDER=anthropic
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# ---- Database (optional — only if using Supabase instead of SQLite) ---
# DATABASE_URL=postgresql://...

# -----------------------------------------------------------------------
# Positional Trading Module (Minervini VCP Strategy)
# Capital: ₹1,00,000 separate pool (set in config.py POSITIONAL_CAPITAL)
# -----------------------------------------------------------------------

# ---- Telegram Notifications -------------------------------------------
# Optional — positional alerts sent to Telegram at 4:30 PM IST each day.
# Step 1: Create a bot via @BotFather on Telegram → copy the token below
# Step 2: Start a chat with your bot (or add it to a group/channel)
# Step 3: Get chat ID:
#   curl "https://api.telegram.org/bot<TOKEN>/getUpdates"
#   Look for "chat":{"id": <YOUR_CHAT_ID>} in the response
# Leave empty to disable Telegram alerts (the rest of the app still works).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---- Positional Broker ------------------------------------------------
# paper      — Paper trading, default (no real orders, safe to use)
# sharekhan  — Sharekhan API (add credentials below when ready)
# zerodha    — Zerodha Kite API (add credentials below when ready)
POSITIONAL_BROKER=paper

# ---- Sharekhan API (only when POSITIONAL_BROKER=sharekhan) ------------
# SHAREKHAN_API_KEY=
# SHAREKHAN_CLIENT_ID=
# SHAREKHAN_PASSWORD=

# ---- Zerodha Kite API (only when POSITIONAL_BROKER=zerodha) -----------
# Kite Connect subscription required (₹2000/month).
# Access token must be refreshed daily — see positional/broker.py.
# ZERODHA_API_KEY=
# ZERODHA_ACCESS_TOKEN=
